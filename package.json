{
	"name": "aijourney",
	"private": true,
	"version": "0.1.0",
	"description": "Mito AI Journey — Personalized AI experimentation platform",
	"scripts": {
		"start": "docker compose up -d --build",
		"stop": "docker compose down",
		"watch": "docker compose up -d --wait dynamodb-local redis && pnpm run seed:db && pnpm --filter @aijourney/shared build && pnpm -r --parallel dev",
		"build": "pnpm -r build",
		"dev": "pnpm -r --parallel dev",
		"lint": "pnpm -r lint",
		"lint:fix": "pnpm -r lint:fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "pnpm -r test",
		"clean": "pnpm -r clean && rm -rf node_modules",
		"seed:db": "tsx scripts/seed-db.ts",
		"seed:kb": "tsx scripts/seed-kb.ts"
	},
	"devDependencies": {
		"@aws-sdk/client-dynamodb": "^3.700.0",
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^9.0.0",
		"prettier": "^3.4.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.56.1"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=9.0.0"
	},
	"packageManager": "pnpm@9.15.4"
}
