NODE_ENV=development
PORT=3000

# DynamoDB (local development)
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=eu-central-1

# ElastiCache Redis (local: plain Redis)
REDIS_URL=redis://localhost:6379

# AWS (use mito815 profile credentials)
AWS_PROFILE=mito815

# KB Builder — S3 bucket for Bedrock Knowledge Base ingestion
KB_S3_BUCKET=aijourney-kb-data
KB_S3_PREFIX=kb-documents/

# RAG Provider: "self" (Qdrant + OpenAI embeddings) or "bedrock" (AWS Bedrock KB)
RAG_PROVIDER=self
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_chunks

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Cognito (fill after Terraform creates pool)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_ISSUER=

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAIN=mito.hu


